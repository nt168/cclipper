static void	server_restart_ha(nt_rtc_t *rtc)
{
	char		*error = NULL;
	nt_ha_config_t	*ha_config = nt_malloc(NULL, sizeof(nt_ha_config_t));

	nt_unset_child_signal_handler();

#ifdef HAVE_PTHREAD_PROCESS_SHARED
	/* Disable locks so main process doesn't hang on logging if a process was              */
	/* killed during logging. The locks will be re-enabled after logger is reinitialized   */
	nt_locks_disable();
#endif
	nt_ha_kill();

	nt_set_child_signal_handler();

	/* restart logger because it could have been stuck in lock */
	if (SUCCEED != server_restart_logger(&error))
	{
		nt_error("cannot restart logger: %s", error);
		nt_free(error);
		exit(EXIT_FAILURE);
	}

#ifdef HAVE_PTHREAD_PROCESS_SHARED
	nt_locks_enable();
#endif

	ha_config->ha_node_name =	CONFIG_HA_NODE_NAME;
	ha_config->ha_node_address =	CONFIG_NODE_ADDRESS;
	ha_config->default_node_ip =	nt_config_listen_ip;
	ha_config->default_node_port =	nt_config_listen_port;
	ha_config->ha_status =		NT_NODE_STATUS_STANDBY;

	if (SUCCEED != nt_ha_start(rtc, ha_config, &error))
	{
		nt_log(LOG_LEVEL_CRIT, "cannot start HA manager: %s", error);
		nt_free(error);
		exit(EXIT_FAILURE);
	}

	ha_status = NT_NODE_STATUS_STANDBY;
}

# FunVariant.cnf - 函数定义变体配置文件
# 
# 本配置文件用于指导搜索工具识别C语言函数定义的各种变体形式
# 注释以 # 开头，空行将被忽略
#
# 支持的模式标记：
#   {FUNC_NAME}  - 函数名占位符
#   {RET_TYPE}   - 返回类型占位符
#   {PARAMS}     - 参数列表占位符

# ==============================================================
# 1. 单行函数定义
# ==============================================================

# 标准单行定义
# 示例: int func_name(int a, char *b) { ... }
{RET_TYPE} {FUNC_NAME}({PARAMS}) {

# 单行定义，大括号另起一行
# 示例: int func_name(int a, char *b)
#       {
{FUNC_NAME}({PARAMS})

# ==============================================================
# 2. 多行函数定义（返回值和函数名分行）
# ==============================================================

# 返回值独立一行，然后函数名
# 示例: static int
#       func_name(int a, char *b) {
{RET_TYPE}
{FUNC_NAME}({PARAMS})

# ==============================================================
# 3. 多行参数列表
# ==============================================================

# 参数列表跨多行（带反斜杠续行）
# 示例: int func_name(int a,
#                     char *b,
#                     double c) {
{FUNC_NAME}\(
{PARAMS}

# 参数列表跨多行（不带反斜杠）
# 示例: int func_name(int a,
#                     char *b,
#                     double c)
#       {
{FUNC_NAME}\(

# ==============================================================
# 4. 特殊修饰符
# ==============================================================

# 带 static 修饰
static {RET_TYPE} {FUNC_NAME}({PARAMS})

# 带 inline 修饰
inline {RET_TYPE} {FUNC_NAME}({PARAMS})

# 带 __attribute__ 修饰
{RET_TYPE} {FUNC_NAME}({PARAMS}) __attribute__

# 带 API 导出宏（Windows DLL）
__declspec(dllexport) {RET_TYPE} {FUNC_NAME}({PARAMS})

# ==============================================================
# 5. 函数指针相关
# ==============================================================

# 函数指针定义
# 示例: int (*func_ptr)(int a, char *b)
\(*{FUNC_NAME}\)

# ==============================================================
# 6. 函数声明
# ==============================================================

# 函数声明（在 .h 文件中）
# 示例: int func_name(int a, char *b);
{RET_TYPE} {FUNC_NAME}({PARAMS});

# 带 extern 的声明
extern {RET_TYPE} {FUNC_NAME}({PARAMS});

# ==============================================================
# 7. 宏定义
# ==============================================================

# 宏定义形式
# 示例: #define FUNC_NAME(x) do { ... } while(0)
#define {FUNC_NAME}

# 宏定义带参数
#define {FUNC_NAME}\(